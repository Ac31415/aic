prefix=${pcfiledir}/../../
libdir=${prefix}/lib
includedir=${prefix}/include/gz/plugin3

Name: Gazebo plugin loader
Description: A set of plugin loader classes for robot applications
Version: 3.1.0
Requires: gz-plugin3 = 3.1.0
Requires.private: 
Libs: -L${libdir} -lgz-plugin3-loader 
Libs.private: -ldl
CFLags: -I${includedir} 
